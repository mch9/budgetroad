generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Event {
  id         BigInt   @id @default(autoincrement())
  visitorId  String   @map("visitor_id") @db.VarChar(64)
  sessionId  String?  @map("session_id") @db.VarChar(64)
  eventName  String   @map("event_name") @db.VarChar(64)
  properties Json?
  isDev      Boolean  @default(false) @map("is_dev")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt(sort: Desc)], map: "events_created_at_desc_idx")
  @@index([visitorId, createdAt(sort: Desc)], map: "events_visitor_created_at_desc_idx")
  @@index([eventName, createdAt(sort: Desc)], map: "events_name_created_at_desc_idx")
  @@map("events")
}
